[
  // ═══════════════════════════════════════════════════════════
  // How to use this template
  //
  // 1. Pick the entries you need and fill in the placeholder fields
  // 2. See the comment above each entry for valid provider/endpoint values
  // 3. Remove entries you don't need; separate multiple entries with commas
  // ═══════════════════════════════════════════════════════════

  // DeepSeek — provider: "deepseek", endpoint: "deepseek"
  {
    "id": "<your-model-id>",
    "label": "<your-display-name>",
    "provider": "<fill>",
    "endpoint": "<fill>",
    "family": "deepseek",
    "version": "4",
    "maxInputTokens": 616000,
    "maxOutputTokens": 384000,
    "thinking": true,
    "maxTools": 128,
    "thinkingConfig": {
      "default": "high",
      "options": [
        { "value": "high", "label": "High", "requestFields": { "thinking": { "type": "enabled" }, "reasoning_effort": "high" } },
        { "value": "max", "label": "Max", "requestFields": { "thinking": { "type": "enabled" }, "reasoning_effort": "max" } },
        { "value": "none", "label": "None", "requestFields": { "thinking": { "type": "disabled" } } }
      ]
    }
  },

  // MiniMax — provider: "minimax", endpoint: "minimaxi.com" | "minimax.io"
  {
    "id": "<your-model-id>",
    "label": "<your-display-name>",
    "provider": "<fill>",
    "endpoint": "<fill>",
    "family": "minimax",
    "version": "2",
    "maxInputTokens": 204800,
    "maxOutputTokens": 196608,
    "thinking": true,
    "maxTools": 64,
    "contentTag": "think",
    "thinkingConfig": {
      "default": "adaptive",
      "options": [
        { "value": "adaptive", "label": "Adaptive", "requestFields": { "thinking": { "type": "adaptive" } } },
        { "value": "disabled", "label": "None", "requestFields": { "thinking": { "type": "disabled" } } }
      ]
    }
  },

  // MiniMax (vision) — provider: "minimax", endpoint: "minimaxi.com" | "minimax.io"
  {
    "id": "<your-model-id>",
    "label": "<your-display-name>",
    "provider": "<fill>",
    "endpoint": "<fill>",
    "family": "minimax",
    "version": "3",
    "maxInputTokens": 204800,
    "maxOutputTokens": 196608,
    "thinking": true,
    "imageInput": true,
    "maxTools": 64,
    "contentTag": "think",
    "thinkingConfig": {
      "default": "adaptive",
      "options": [
        { "value": "adaptive", "label": "Adaptive", "requestFields": { "thinking": { "type": "adaptive" } } },
        { "value": "disabled", "label": "None", "requestFields": { "thinking": { "type": "disabled" } } }
      ]
    }
  },

  // Moonshot / Kimi — provider: "moonshot", endpoint: "moonshot.cn" | "moonshot.ai"
  {
    "id": "<your-model-id>",
    "label": "<your-display-name>",
    "provider": "<fill>",
    "endpoint": "<fill>",
    "family": "kimi",
    "version": "k2.6",
    "maxInputTokens": 262144,
    "maxOutputTokens": 65536,
    "thinking": true,
    "imageInput": true,
    "maxTools": 128,
    "thinkingConfig": {
      "default": "enabled",
      "options": [
        { "value": "enabled", "label": "Enabled", "requestFields": { "thinking": { "type": "enabled" } } },
        { "value": "enabled_keep", "label": "Enabled (Keep)", "requestFields": { "thinking": { "type": "enabled", "keep": "all" } } },
        { "value": "disabled", "label": "Disabled", "requestFields": { "thinking": { "type": "disabled" } } }
      ]
    }
  },

  // Qwen / Tongyi — provider: "qwen", endpoint: "cn" | "us" | "sgp" | "eu"
  {
    "id": "<your-model-id>",
    "label": "<your-display-name>",
    "provider": "<fill>",
    "endpoint": "<fill>",
    "family": "qwen",
