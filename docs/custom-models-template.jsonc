    "maxInputTokens": 991000,
    "maxOutputTokens": 65536,
    "thinking": true,
    "maxTools": 128,
    "thinkingConfig": {
      "default": "adaptive",
      "options": [
        { "value": "adaptive", "label": "Adaptive", "requestFields": { "enable_thinking": true } },
        { "value": "disabled", "label": "None", "requestFields": { "enable_thinking": false } }
      ]
    }
  },

  // Qwen / Tongyi (vision) — provider: "qwen", endpoint: "cn" | "us" | "sgp" | "eu"
